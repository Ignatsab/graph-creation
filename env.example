# .env.example  →  copy to .env and fill in your values

# ── Your existing PostgreSQL database ────────────────────────────────────────
POSTGRES_URI=postgresql://your-host:5432
POSTGRES_USERNAME=your_user
POSTGRES_PASSWORD=your_password
POSTGRES_DATABASE=your_database
POSTGRES_SCHEMA=public          # schema where your tables live

# ── Memgraph (started via docker compose up) ─────────────────────────────────
MEMGRAPH_URI=bolt://localhost:7687
MEMGRAPH_USERNAME=              # leave empty — Memgraph auth is off by default
MEMGRAPH_PASSWORD=
MEMGRAPH_DATABASE=memgraph

# ── Optional ─────────────────────────────────────────────────────────────────
INGEST_LIMIT=100                # rows per table for test runs; remove or set 0 for full load
