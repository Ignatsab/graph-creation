# .env.example
# Copy to .env and fill in your values.
# Used by docker-compose.yml and loaded by ingest.py via os.getenv().

# ── PostgreSQL (source) ────────────────────────────────────────────────────────
POSTGRES_URI=postgresql://localhost:5432
POSTGRES_USERNAME=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DATABASE=mydb
POSTGRES_SCHEMA=public
POSTGRES_PORT=5432         # host port exposed by docker-compose

# ── Memgraph (target) ─────────────────────────────────────────────────────────
MEMGRAPH_URI=bolt://localhost:7687
MEMGRAPH_USERNAME=        # leave empty if Memgraph auth is disabled (default)
MEMGRAPH_PASSWORD=
MEMGRAPH_DATABASE=memgraph
MEMGRAPH_BOLT_PORT=7687   # host port exposed by docker-compose
MEMGRAPH_HTTP_PORT=7444
MEMGRAPH_LAB_PORT=3000    # Memgraph Lab browser UI
