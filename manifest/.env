# .env.example  →  copy to .env and fill in your values

# ── Your existing PostgreSQL database ────────────────────────────────────────
POSTGRES_URI=postgresql://your-host:5432
POSTGRES_USERNAME=your_user
POSTGRES_PASSWORD=your_password
POSTGRES_DATABASE=pilothouse
POSTGRES_SCHEMA=pilothouse_admin

# ── Table filtering (optional) ────────────────────────────────────────────────
# Only ingest tables whose names start with these prefixes.
# Comma-separated. Leave empty to ingest ALL tables in the schema.
TABLE_PREFIXES=apm_

# ── Memgraph (only needed for ingest.py, not inspect_schema.py) ──────────────
MEMGRAPH_URI=bolt://localhost:7687
MEMGRAPH_USERNAME=
MEMGRAPH_PASSWORD=
MEMGRAPH_DATABASE=memgraph

# ── Optional ──────────────────────────────────────────────────────────────────
# Rows per table for test runs; remove or set 0 for full load
INGEST_LIMIT=100
